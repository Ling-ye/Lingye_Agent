LLM_API_KEY=sk-
LLM_BASE_URL=https://aihubmix.com/v1
LLM_MODEL_ID=coding-glm-5-free
LLM_TIMEOUT=180

SUPPORTED_PROVIDERS=openai,aihubmix,deepseek,qwen,modelscope,kimi,zhipu,ollama,vllm,local


OPENAI_API_KEY=
AIHUBMIX_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MODELSCOPE_API_KEY=

KIMI_API_KEY=
MOONSHOT_API_KEY=

ZHIPU_API_KEY=
GLM_API_KEY=

OLLAMA_API_KEY=
OLLAMA_HOST=http://localhost:11434

VLLM_API_KEY=
VLLM_HOST=http://localhost:8000


DEBUG=false
LOG_LEVEL=INFO
TEMPERATURE=0.7
MAX_TOKENS= 1024


# ================================
# Qdrant 向量数据库配置 - 获取API密钥：https://cloud.qdrant.io/
# ================================
# 使用Qdrant云服务 (推荐)
QDRANT_URL=https://.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=

# 或使用本地Qdrant (需要Docker)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Qdrant集合配置
QDRANT_COLLECTION=
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30
# 开启系统/环境代理时，Qdrant REST 经代理易出现 SSL EOF；0=httpx 不读 HTTP(S)_PROXY（让 Qdrant 直连或走 TUN）
QDRANT_HTTP_TRUST_ENV=0

# RAG 知识库专用 Qdrant 集合名（与上方 QDRANT_COLLECTION 记忆向量库无关）。不设置时默认为 rag_knowledge_base。
# 更换 embedding 维度后须使用新集合并重新索引；例如本地 384 维：rag_knowledge_base_384
RAG_QDRANT_COLLECTION=rag_knowledge_base_384

# ================================
# Neo4j 图数据库配置 - 获取API密钥：https://neo4j.com/cloud/aura/
# ================================
# 使用Neo4j Aura云服务 (推荐)
# 若 neo4j+s 报 SSL 证书链错误（常见于公司代理/HTTPS 扫描），可改用 neo4j+ssc（信任自签名链，安全性较弱；更好做法是导入企业根证书后仍用 neo4j+s）
# NEO4J_URI=neo4j+s://.databases.neo4j.io # 正常网络使用url
NEO4J_URI=neo4j+ssc://.databases.neo4j.io # 开启代理后使用url
NEO4J_USERNAME=
NEO4J_PASSWORD=

# 或使用本地Neo4j (需要Docker)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=
# NEO4J_PASSWORD=

# Neo4j连接配置
# Aura 实例逻辑库名与实例 ID 一致（Query API: /db/deeffd0e/...）
NEO4J_DATABASE=
NEO4J_MAX_CONNECTION_LIFETIME=300
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

# ==========================
# 嵌入（Embedding）配置示例 - 可从阿里云控制台获取：https://dashscope.aliyun.com/
# ==========================
# 云服务
# - 若为空，dashscope 默认 text-embedding-v3；local 默认 sentence-transformers/all-MiniLM-L6-v2
# EMBED_MODEL_TYPE=dashscope
# EMBED_MODEL_NAME=text-embedding-v3
# EMBED_API_KEY=sk-
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# QDRANT_VECTOR_SIZE=1024 # text-embedding-v3 = 1024维

# 本地（完全离线：下面三项一起用）
# 1) EMBED_MODEL_NAME 填本机已下载模型的文件夹绝对路径，例如 E:/models/all-MiniLM-L6-v2（不要用 sentence-transformers/... 这种 Hub ID，否则会访问 huggingface.co）
# 2) EMBED_OFFLINE=1 禁止 Hub 联网；模型必须已在该路径或 HF 缓存中完整存在
# 3) EMBED_STRICT_LOCAL=1 嵌入失败时不回退 DashScope，仅 local → TF-IDF
#pip install -U "huggingface_hub>=0.20"
# 一次性下载（需能访问外网或镜像）：HF_ENDPOINT=https://hf-mirror.com 或配置代理后执行
# hf download sentence-transformers/all-MiniLM-L6-v2 --local-dir E:/models/all-MiniLM-L6-v2
EMBED_MODEL_TYPE=local
EMBED_MODEL_NAME=E:/models/all-MiniLM-L6-v2
EMBED_OFFLINE=1
EMBED_STRICT_LOCAL=1
EMBED_API_KEY=
EMBED_BASE_URL=
QDRANT_COLLECTION= #换EMBED_MODEL需要换维度，需要新建一个collection
QDRANT_VECTOR_SIZE=384

