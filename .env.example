LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=
LLM_TIMEOUT=60

SUPPORTED_PROVIDERS=openai,aihubmix,deepseek,qwen,modelscope,kimi,zhipu,ollama,vllm,local


OPENAI_API_KEY=
AIHUBMIX_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MODELSCOPE_API_KEY=

KIMI_API_KEY=
MOONSHOT_API_KEY=

ZHIPU_API_KEY=
GLM_API_KEY=

OLLAMA_API_KEY=
OLLAMA_HOST=http://localhost:11434

VLLM_API_KEY=
VLLM_HOST=http://localhost:8000


DEBUG=false
LOG_LEVEL=INFO
TEMPERATURE=0.7
MAX_TOKENS= 1024


# ================================
# Qdrant 向量数据库配置 - 获取API密钥：https://cloud.qdrant.io/
# ================================
# 使用Qdrant云服务 (推荐)
QDRANT_URL=
QDRANT_API_KEY=

# 或使用本地Qdrant (需要Docker)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Qdrant集合配置
QDRANT_COLLECTION=
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30
# 代理环境下若 Qdrant 报 SSL UNEXPECTED_EOF：QDRANT_HTTP_TRUST_ENV=0（REST 不走 HTTP(S)_PROXY）
# 仍失败可试：QDRANT_REST_DISABLE_KEEPALIVE=1
# 切勿对 Qdrant 开 QDRANT_PREFER_GRPC=1（gRPC 多数 HTTP 代理不支持）
QDRANT_HTTP_TRUST_ENV=0 #开启代理后启用此设置


# ================================
# Neo4j 图数据库配置 - 获取API密钥：https://neo4j.com/cloud/aura/
# ================================
# 使用Neo4j Aura云服务 (推荐)
# 若 neo4j+s 报 SSL 证书链错误（常见于公司代理/HTTPS 扫描），可改用 neo4j+ssc（信任自签名链，安全性较弱；更好做法是导入企业根证书后仍用 neo4j+s）
# NEO4J_URI=neo4j+s:// # 正常网络使用url
NEO4J_URI=neo4j+ssc:// # 开启代理后使用url
NEO4J_USERNAME=
NEO4J_PASSWORD=

# 或使用本地Neo4j (需要Docker)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=

# Neo4j连接配置
# Aura 实例逻辑库名与实例 ID 一致
NEO4J_DATABASE=
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

# ==========================
# 嵌入（Embedding）配置示例 - 可从阿里云控制台获取：https://dashscope.aliyun.com/
# ==========================
# - 若为空，dashscope 默认 text-embedding-v3；local 默认 sentence-transformers/all-MiniLM-L6-v2
EMBED_MODEL_TYPE=
EMBED_MODEL_NAME=
EMBED_API_KEY=
EMBED_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QDRANT_VECTOR_SIZE=1024 # text-embedding-v3 = 1024维


# EMBED_MODEL_TYPE=local
# EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBED_API_KEY=
# EMBED_BASE_URL=
# QDRANT_VECTOR_SIZE=384